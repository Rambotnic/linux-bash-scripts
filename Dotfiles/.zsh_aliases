alias ff="fastfetch"
alias cls="clear; fastfetch"
alias cdq="zoxide query -l -s | more"
alias ls="ls --color --hyperlink=always"
alias lsa="ls --color -a --hyperlink=always"
alias kitty-theme="kitty +kitten themes --reload-in=all"
alias reset-meta-key="kwriteconfig5 --file ~/.config/kwinrc --group ModifierOnlyShortcuts --key Meta 'org.kde.plasmashell>"
alias update-millennium="curl -fsSL "https://raw.githubusercontent.com/SteamClientHomebrew/Millennium/main/scripts/install.sh" | sh"
